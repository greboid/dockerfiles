FROM {{image "golang"}} AS build

ARG TAG="{{github_tag "haileyok/cocoon"}}"

RUN set -eux; \
    apk add --no-cache \
        {{range $key, $value := alpine_packages "git" -}}
        {{$key}}={{$value}}\
        {{end}}; \
    git clone --depth=1 -b $TAG --single-branch https://github.com/haileyok/cocoon /src; \
    cd /src; \
    ls; \
    CGO_ENABLED=0 go build -a -ldflags '-extldflags "-static"' -trimpath -ldflags="-s -w -buildid= -X main.Version=$TAG" -o cocoon ./cmd/cocoon; \
    go-licenses save ./... --ignore github.com/ipfs/bbloom --ignore github.com/multiformats/go-base36 --save_path=/notices;

FROM {{image "base"}}

COPY --from=build /src/cocoon /cocoon
COPY --from=build /notices /notices
EXPOSE 8080
ENTRYPOINT ["/cocoon"]
CMD ["run"]
