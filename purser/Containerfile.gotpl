FROM {{image "golang"}} AS build
{{template "clone" (map "repo" "csmith/purser")}}
ENV CGO_ENABLED=0
ENV GOEXPERIMENT=jsonv2
{{template "build-go" (map)}}
{{template "go-licenses" (map "ignores" (arr "github.com/xi2/xz" "modernc.org/mathutil"))}}
{{template "prepare" (map "name" "purser" "volumes" (arr "/data/cache" "/data/output"))}}
{{template "runtime" (map "name" "purser" "volumes" (arr "/data/cache" "/data/output"))}}
