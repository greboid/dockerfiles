{{- $repo := "csmith/centauri" -}}
{{- $binary := "centauri" -}}
FROM {{image "golang"}} AS build
{{ create_volumes "/home/nonroot/.config" "/data" }}
{{ checkout_tag $repo }}
{{ go_build $repo $binary "cmd/dex" (list "lego_httpreq") (list) (list) }}
{{ from_base_add_binary $binary (list) (list) }}
