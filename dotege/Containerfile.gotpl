{{- $repo := "csmith/dotege" -}}
{{- $binary := "dotege" -}}
FROM {{image "golang"}} AS build
{{ create_volumes (list "/config" "/certs" "/output") }}
{{ copy_directories $repo "/templates" }}
{{ checkout_tag $repo }}
{{ go_build $repo $binary "cmd/dotege" (list "lego_httpreq") (list) (list) }}
{{ from_base_add_binary $binary (list) (list) }}
