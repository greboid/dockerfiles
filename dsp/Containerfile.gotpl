FROM {{image "golang"}} AS build
{{template "clone" (map "repo" "greboid/dsp")}}
ENV CGO_ENABLED=0
{{template "build-go" (map "subdir" "./cmd")}}
{{template "go-licenses" (map)}}
{{template "prepare" (map "name" "dsp")}}
{{template "runtime" (map "name" "dsp" "runtime_image" "baseroot" "exposes" (arr "8080"))}}
