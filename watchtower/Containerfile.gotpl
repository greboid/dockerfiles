{{- $repo := "containrrr/watchtower" -}}
FROM {{image "golang"}} AS build

{{ checkout_tag $repo }}
COPY disable-slack.patch /
WORKDIR /src/{{ $repo }}
RUN git apply /disable-slack.patch
{{ go_build $repo "watchtower" "" (list) (list (printf "github.com/containrrr/watchtower/internal/meta.Version=$TAG%s" (tagify $repo))) (list) }}
{{ create_volumes "/home/nonroot/.config" "/data" }}
{{ from_base_add_binary "centauri" (list) (list) }}
