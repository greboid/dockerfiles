{{- $repo := "emersion/soju" -}}
FROM {{image "golang"}} AS build

{{ checkout_tag "csmith/certwrapper" }}
{{ go_build "csmith/certwrapper" "certwrapper" "" (list "lego_httpreq") (list) (list) }}
{{ checkout_tag $repo }}
{{ go_build $repo "soju" "cmd/soju" (list) (list) (list "git.sr.ht/~emersion/soju") }}
{{ go_build $repo "sojuctl" "cmd/sojuctl" (list) (list) (list "git.sr.ht/~emersion/soju") }}
{{ create_volumes "/data" }}
{{ from_base_add_binary "centauri" (list) (list) }}
