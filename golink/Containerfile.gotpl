FROM {{image "golang"}} AS build
{{ checkout_commit "tailscale/golink" "main" "3d62a353ac8b5467b433ad96d686d3388ad01e34" }}
ARG TS={{github_tag "tailscale/tailscale"}}
RUN go get -u tailscale.com@$TS; \
    go mod tidy
{{ go_build "tailscale/golink" "golink" "cmd/golink" (list) (list) (list "modernc.org/mathutil") }}
{{ from_base_add_binary "golink" (list) (list "--sqlitedb" "/home/nonroot/golink.db") }}
