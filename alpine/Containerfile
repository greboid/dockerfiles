# Generated from https://github.com/greboid/dockerfiles/blob/master/alpine/Containerfile.gotpl
# BOM: {"alpine":"3.24.0"}

FROM reg.g5d.dev/alpine AS verify

ARG ARCHIVE_URL="https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/x86_64/alpine-minirootfs-3.24.0-x86_64.tar.gz"
ARG ARCHIVE_SUM="de9a11c0e0e7e9c94db3ed8af7b450eafc0b13687bd7e9199d55050f20aa0a89"

RUN apk add --no-cache curl
RUN set -eux; \
    curl -sfLo fs.tar.gz $ARCHIVE_URL; \
    echo "$ARCHIVE_SUM *fs.tar.gz" | sha256sum -wc -; \
    mkdir -p /fs; \
    tar -C /fs -z -xf fs.tar.gz
RUN echo "[advice]" > /fs/etc/gitconfig && echo "    detachedHead = false" >> /fs/etc/gitconfig

FROM scratch
COPY --from=verify /fs/ /

ENV LANG=en_US.UTF-8
CMD ["/bin/sh"]
